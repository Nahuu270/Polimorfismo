class Vehiculo:
    def mover(self):
        raise NotImplementedError(
            "Este método debe ser sobrescrito por las subclases"
        )

class Coche(Vehiculo):
    def mover(self):
        return "El coche está avanzando por la carretera."

class Bicicleta(Vehiculo):
    def mover(self):
        return "La bicicleta está pedaleando."

def main():
    vehiculos = [
        Coche(),
        Bicicleta(),
        Coche(),
        Bicicleta()
    ]

    for vehiculo in vehiculos:
        print(f"{vehiculo.__class__.__name__}: {vehiculo.mover()}")

if __name__ == "__main__":
    main()
