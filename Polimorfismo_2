class Animal:
    def hacer_sonido(self):
        raise NotImplementedError(
            "Este método debe ser sobrescrito por las subclases"
        )

class Perro(Animal):
    def hacer_sonido(self):
        return "Guau"

class Gato(Animal):
    def hacer_sonido(self):
        return "Miau"

def main():
    animales = [
        Perro(),
        Gato(),
        Perro(),
        Gato()
    ]
    for animal in animales:
        print(f"{animal.__class__.__name__}: {animal.hacer_sonido()}")


if __name__ == "__main__":
    main()
